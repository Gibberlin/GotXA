FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash coreutils netcat-traditional \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY modbus_plc_server.py .

RUN pip install --no-cache-dir \
    pymodbus==3.5.0

RUN chmod +x ./modbus_plc_server.py

CMD ["python3", "./modbus_plc_server.py"]
