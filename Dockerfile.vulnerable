FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    sqlite3 \
    && rm -rf /var/lib/apt/lists/*

COPY vulnerable_app.py .

RUN pip install --no-cache-dir \
    flask==3.1.3 \
    requests==2.31.0

EXPOSE 5001

CMD ["python3", "vulnerable_app.py"]
